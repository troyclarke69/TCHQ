# Copy to .env in the repo root:  cp .env.example .env
# Docker Compose reads this file via env_file (see docker-compose.yml).

# --- Postgres (db service) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Backend (FastAPI / pydantic-settings) ---
# Use host "db" inside Docker; use "localhost" when running uvicorn on the host.
DATABASE_URL=
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=10080
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Frontend (Vite; only VITE_* vars are exposed to the app) ---
# Use backend hostname in Docker; localhost when running npm run dev on the host.
VITE_API_PROXY_TARGET=http://backend:8000
